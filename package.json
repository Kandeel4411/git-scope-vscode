{
  "name": "git-scope",
  "displayName": "Git Scope",
  "publisher": "Kandeel4411",
  "description": "Explorer filtered to git-changed directories — browse and edit within them",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.110.0"
  },
  "icon": "assets/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitExplorerContainer",
          "title": "Git Scope",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "gitExplorerContainer": [
        {
          "id": "gitExplorer",
          "name": "Changed Directories"
        }
      ]
    },
    "commands": [
      {
        "command": "gitExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "gitExplorer.newFile",
        "title": "New File...",
        "icon": "$(new-file)"
      },
      {
        "command": "gitExplorer.newFolder",
        "title": "New Folder...",
        "icon": "$(new-folder)"
      },
      {
        "command": "gitExplorer.deleteItem",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "gitExplorer.renameItem",
        "title": "Rename...",
        "icon": "$(edit)"
      }
    ],
    "keybindings": [
      {
        "command": "gitExplorer.refresh",
        "key": "shift+r",
        "when": "view == gitExplorer && listFocus"
      },
      {
        "command": "gitExplorer.newFile",
        "key": "a",
        "when": "view == gitExplorer && listFocus"
      },
      {
        "command": "gitExplorer.newFolder",
        "key": "shift+a",
        "when": "view == gitExplorer && listFocus"
      },
      {
        "command": "gitExplorer.renameItem",
        "key": "r",
        "when": "view == gitExplorer && listFocus"
      },
      {
        "command": "gitExplorer.deleteItem",
        "key": "d",
        "when": "view == gitExplorer && listFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitExplorer.refresh",
          "when": "view == gitExplorer",
          "group": "navigation"
        },
        {
          "command": "gitExplorer.newFile",
          "when": "view == gitExplorer",
          "group": "navigation"
        },
        {
          "command": "gitExplorer.newFolder",
          "when": "view == gitExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "gitExplorer.newFile",
          "when": "view == gitExplorer && viewItem == directory",
          "group": "1_new@1"
        },
        {
          "command": "gitExplorer.newFolder",
          "when": "view == gitExplorer && viewItem == directory",
          "group": "1_new@2"
        },
        {
          "command": "gitExplorer.renameItem",
          "when": "view == gitExplorer",
          "group": "2_edit@1"
        },
        {
          "command": "gitExplorer.deleteItem",
          "when": "view == gitExplorer",
          "group": "2_edit@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies",
    "pretest": "npm run compile",
    "test:lua": "sh -c '${LUA_BIN:-lua} test/lua/git_scope_test.lua'",
    "test:js": "mocha \"test/**/*.test.js\"",
    "test": "npm run test:lua && npm run test:js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/proxyquire": "^1.3.31",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "mocha": "^11.7.5",
    "proxyquire": "^2.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
